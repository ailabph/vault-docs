# ---------------------------------------------------------------
# Ollama
# ---------------------------------------------------------------

# Local dev (running backend outside Docker):
#   OLLAMA_HOST=http://localhost:11434
#
# Docker Compose (production/VPS — backend inside container):
#   OLLAMA_HOST=http://host.docker.internal:11434
#
# host.docker.internal only resolves inside Docker containers.
# Use localhost:11434 for local dev.

OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:32b

# ---------------------------------------------------------------
# Upload / Prompt Limits
# ---------------------------------------------------------------

MAX_UPLOAD_SIZE_MB=50
MAX_WORDS_PROMPT=8000

# ---------------------------------------------------------------
# App (frontend only)
# ---------------------------------------------------------------

APP_PORT=3000
