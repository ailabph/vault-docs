# ---------------------------------------------------------------
# Ollama
# ---------------------------------------------------------------

# Local dev — tunnel to remote GPU server, no local port conflict:
#   OLLAMA_HOST=http://localhost:11435
#   (SSH tunnel: -L 11435:localhost:11434)
#
# Local dev — local Ollama instance on default port:
#   OLLAMA_HOST=http://localhost:11434
#
# Docker Compose (VPS — backend inside container):
#   OLLAMA_HOST=http://host.docker.internal:11434
#   (host.docker.internal only resolves inside Docker containers)

OLLAMA_HOST=http://localhost:11435
OLLAMA_MODEL=qwen3.5:35b

# ---------------------------------------------------------------
# Upload / Prompt Limits
# ---------------------------------------------------------------

MAX_UPLOAD_SIZE_MB=50
MAX_WORDS_PROMPT=8000

# ---------------------------------------------------------------
# App (frontend only)
# ---------------------------------------------------------------

APP_PORT=3000
