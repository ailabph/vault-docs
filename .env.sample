# ---------------------------------------------------------------
# Ollama
# ---------------------------------------------------------------

# Set OLLAMA_HOST to match your environment:
#
#   Local dev (tunnel on non-conflicting port):
#     OLLAMA_HOST=http://localhost:11435
#
#   Local dev (local Ollama, default port):
#     OLLAMA_HOST=http://localhost:11434
#
#   VPS / Docker Compose deployment:
#     OLLAMA_HOST=http://host.docker.internal:11434
#     (host.docker.internal resolves to Docker host; only works inside a container)
#
# The value below is for local dev. Change to host.docker.internal for VPS deployment.

OLLAMA_HOST=http://localhost:11435
OLLAMA_MODEL=qwen3.5:35b

# ---------------------------------------------------------------
# Upload / Prompt Limits
# ---------------------------------------------------------------

MAX_UPLOAD_SIZE_MB=50
MAX_WORDS_PROMPT=8000

# ---------------------------------------------------------------
# App (frontend only)
# ---------------------------------------------------------------

APP_PORT=3000
